[resource]
script = ExtResource("1")
item_id = "smart_metal_container"
title = "Пояс с умным металлом"
description = "Инопланетная технология, адаптированная для людей: контейнер с металлоподобной субстанцией, меняющей форму по команде оператора.

За 10-15 секунд материал может стать прутом, щитом, копьём, молотом или другим простым инструментом.
Форма остаётся крайне прочной, поэтому пояс хорош и для импровизированной защиты, и для грубой полевой работы."
equipment_texture = ExtResource("2")
