[resource]
script = ExtResource("1")
item_id = "heavy_rescue_suit"
title = "Тяжёлый костюм спасателя"
is_suit = true
description = "Усиленный аварийно-спасательный скафандр для завалов, разгерметизированных станций и опасных техзон.

Даёт повышенную защиту от радиации, ударов, осколков, высоких температур и жёсткой среды.
Массивный и неудобный, зато позволяет идти туда, где обычный костюм уже не внушает доверия."
equipment_texture = ExtResource("2")
