[resource]
script = ExtResource("1")
item_id = "plasma_cutter"
title = "Плазменный резак"
description = "Ручной инструмент, выпускающий управляемый плазменный луч длиной от нескольких сантиметров до метра.

Режет металл, крепления, люки и почти всё, что вообще можно разрезать в полевых условиях.
Редчайшая модель с батареями на холодном синтезе работает почти вечно и при необходимости становится опасным оружием ближнего боя."
equipment_texture = ExtResource("2")
