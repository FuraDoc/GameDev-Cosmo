[resource]
script = ExtResource("1_o4281")
item_id = "rescue_suit"
title = "Экранированный защитный костюм спасателя"
description = "Защитный костюм для вылазок в опасную среду.

Оснащён встроенной подсветкой и правым наручным плазменным резаком для аварийных работ.
Применение:

проход через опасные зоны;
защита от среды;
освещение тёмных участков;
разрезание тонких перегородок, креплений, завалов;
отпугивание мелких угроз.
"
