[resource]
script = ExtResource("1_dxjkb")
item_id = "analytic_resonator"
title = "Аналитический резонатор"
description = "Наручное устройство с голографическим интерфейсом, закреплённое на предплечье.

Используется для анализа языковых, звуковых, световых и структурных паттернов, а также для взаимодействия с древними системами, интерфейсами и необычными формами коммуникации.
Применение:

дешифровка символов;
работа с древними механизмами;
попытка мирного контакта;
интерпретация сигналов;
поиск “ключа” к чужой логике."
equipment_texture = ExtResource("1_gxety")
