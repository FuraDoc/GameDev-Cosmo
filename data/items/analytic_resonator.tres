[resource]
script = ExtResource("1")
item_id = "analytic_resonator"
title = "Аналитический резонатор"
description = "Наручный комплекс на предплечье и запястье, напоминающий мини-компьютер с набором датчиков и универсальных интерфейсов.

Умеет подключаться к человеческим системам: дверям, замкам, камерам, компьютерам и другим интерфейсам.
Дополнительно анализирует речь, интонации и звуки, переводит на лету и помогает налаживать контакт с живыми существами."
equipment_texture = ExtResource("2")
