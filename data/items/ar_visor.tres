[resource]
script = ExtResource("1")
item_id = "ar_visor"
title = "Визор дополненной реальности"
description = "Продвинутые очки под шлем, способные накладывать поверх мира дополнительный слой полезной информации.

Помогают строить маршрут, видеть внутреннюю структуру небольших объектов и находить скрытые свойства окружения.
Особенно полезны при исследовании помещений, поиске пути, работе с мелкими устройствами и взломе простых систем."
equipment_texture = ExtResource("2")
