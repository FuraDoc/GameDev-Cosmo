[resource]
script = ExtResource("1_kdsip")
item_id = "ar_visor"
title = "Визор-дешифратор дополненной реальности"
description = "Носимый визор с режимом дополненной реальности.

Подсвечивает скрытые контуры, усиливает видимость в темноте и помогает распознавать символы, следы и технологические элементы.
Применение:

осмотр руин;
чтение надписей;
поиск скрытых объектов;
анализ пространства;
обнаружение слабых сигналов и аномальных структур.
"
