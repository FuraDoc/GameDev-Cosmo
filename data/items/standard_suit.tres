[resource]
script = ExtResource("1")
item_id = "standard_suit"
title = "Штатный скафандр"
is_suit = true
description = "Базовый корабельный скафандр, с которого начинается любая спокойная, долгая экспедиция.

Надёжен, прост в обслуживании и не добавляет особых преимуществ.
Подходит для обычных выходов и повседневной работы за пределами корабля."
equipment_texture = ExtResource("2")
